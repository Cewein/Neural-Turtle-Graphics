 <node id="9438771642" visible="true" version="5" changeset="116458304" timestamp="2022-01-22T09:08:36Z" user="神楽坂矢来整骨院" uid="14911497" lat="35.7023845" lon="139.7326174">
  <tag k="addr:city" v="新宿区"/>
  <tag k="addr:housenumber" v="木下ビル 3F"/>
  <tag k="addr:neighbourhood" v="61"/>
  <tag k="addr:postcode" v="162-0805"/>
  <tag k="addr:province" v="東京都"/>
  <tag k="addr:quarter" v="矢来町"/>
  <tag k="amenity" v="doctors"/>
  <tag k="description" v="&quot;神楽坂、飯田橋、市ヶ谷、江戸川橋エリアの根本治療を行う整骨院です。 腰痛、肩こり、首こり、膝痛などの慢性症状や、姿勢矯正、骨盤矯正などの身体のゆがみ、 捻挫、打撲などの急性症状、頭痛、めまい、倦怠感、不眠、便秘などの自律神経症状まで対応可能な整骨院です。 手技マッサージ、揉みほぐし、電気療法だけではなく、コンピューターシステムを使用し骨格や神経、筋肉に対して適切な振動を計算し、 施術ができるようになった最先端の施術も行っています。 体の不調は首や背骨、骨盤などの歪みからきていることが多いです。 あなたの"/>
  <tag k="name" v="神楽坂矢来整骨院"/>
  <tag k="operator" v="スカイ・フュージョン合同会社"/>
  <tag k="operator:type" v="business"/>
  <tag k="phone" v="03-5579-2839"/>
  <tag k="website" v="https://kagurayarai.jp/"/>
 </node>
